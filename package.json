{
  "name": "codex-discord",
  "version": "0.2.0",
  "packageManager": "pnpm@9.15.9",
  "description": "A local Discord bridge for Codex that adds persistent threads, voice input/output, hot-reloaded message config, and hands-free coding from a single text or voice channel.",
  "main": "dist/index.js",
  "files": [
    "dist",
    "assets/defaults",
    "scripts/setup.mjs",
    "README.md"
  ],
  "bin": {
    "codex-discord": "dist/cli.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wj-duda/codex-discord.git"
  },
  "license": "MIT",
  "homepage": "https://github.com/wj-duda/codex-discord#readme",
  "bugs": {
    "url": "https://github.com/wj-duda/codex-discord/issues"
  },
  "keywords": [
    "codex",
    "discord",
    "voice",
    "whisper",
    "piper",
    "automation",
    "cli",
    "agent"
  ],
  "scripts": {
    "setup": "node scripts/setup.mjs",
    "build": "tsc -p tsconfig.json",
    "prepare": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "cli": "tsx src/cli.ts",
    "dev": "tsx watch src/index.ts",
    "check": "tsc --noEmit -p tsconfig.json"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@discordjs/voice": "^0.19.0",
    "@discordjs/opus": "^0.10.0",
    "@openai/codex": "latest",
    "discord.js": "^14.25.1",
    "dotenv": "^17.2.3",
    "tweetnacl": "^1.0.3"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
