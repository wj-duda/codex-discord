{
  "name": "codex-discord",
  "version": "0.1.0",
  "packageManager": "pnpm@9.15.9",
  "description": "A local bridge between a Discord channel and codex app-server.",
  "main": "dist/index.js",
  "bin": {
    "codex-discord": "dist/cli.js"
  },
  "scripts": {
    "setup": "node scripts/setup.mjs",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "cli": "tsx src/cli.ts",
    "dev": "tsx watch src/index.ts",
    "check": "tsc --noEmit -p tsconfig.json"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@discordjs/voice": "^0.19.0",
    "@discordjs/opus": "^0.10.0",
    "@openai/codex": "latest",
    "discord.js": "^14.25.1",
    "dotenv": "^17.2.3",
    "tweetnacl": "^1.0.3"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
