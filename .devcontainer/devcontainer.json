{
  "name": "codex-discord-bridge",
  "dockerComposeFile": "docker-compose.yml",
  "service": "app",
  "workspaceFolder": "/workspace",
  "mounts": [
    "source=${localEnv:HOME}/.codex,target=/home/node/.codex,type=bind,consistency=cached",
    "source=${localEnv:HOME}/.config/gh,target=/home/node/.config/gh,type=bind,consistency=cached",
    "source=${localEnv:HOME}/.gitconfig,target=/home/node/.gitconfig,type=bind,consistency=cached"
  ],
  "containerEnv": {
    "FFMPEG_PATH": "/usr/bin/ffmpeg",
    "WHISPER_CPP_PATH": "/usr/local/bin/whisper-cli",
    "WHISPER_MODEL_PATH": "https://huggingface.co/ggerganov/whisper.cpp/resolve/main/ggml-small.bin",
    "PIPER_PATH": "/usr/local/bin/piper",
    "PIPER_MODEL_PATH": "https://huggingface.co/rhasspy/piper-voices/resolve/main/pl/pl_PL/gosia/medium/pl_PL-gosia-medium.onnx",
    "PIPER_MODEL_CONFIG_PATH": "https://huggingface.co/rhasspy/piper-voices/resolve/main/pl/pl_PL/gosia/medium/pl_PL-gosia-medium.onnx.json"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "openai.chatgpt",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "ms-vscode.vscode-typescript-next"
      ]
    }
  },
  "postCreateCommand": "bash -lc 'pnpm install --frozen-lockfile'",
  "remoteUser": "node"
}
