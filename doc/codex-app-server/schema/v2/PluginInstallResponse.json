{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PluginInstallResponse",
  "type": "object",
  "required": [
    "appsNeedingAuth"
  ],
  "properties": {
    "appsNeedingAuth": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/AppSummary"
      }
    }
  },
  "definitions": {
    "AppSummary": {
      "description": "EXPERIMENTAL - app metadata summary for plugin-install responses.",
      "type": "object",
      "required": [
        "id",
        "name"
      ],
      "properties": {
        "description": {
          "type": [
            "string",
            "null"
          ]
        },
        "id": {
          "type": "string"
        },
        "installUrl": {
          "type": [
            "string",
            "null"
          ]
        },
        "name": {
          "type": "string"
        }
      }
    }
  }
}